################################################################################
## NAARNI — Production Environment (Azure VM)
##
## SAFE TO COMMIT — no secrets in this file.
## All credentials are injected from GitHub Secrets at deploy time.
## See: .github/workflows/deploy-naarni-azure.yml
################################################################################

# Docker Hub image config
NAARNI_DOCKERHUB_ORG=naarnimd
IMAGE_TAG=latest

################################################################################
## AUTH — Microsoft 365 OIDC
################################################################################
AUTH_TYPE=oidc
# USER_AUTH_SECRET       → from GitHub secret
# OAUTH_CLIENT_ID        → from GitHub secret
# OAUTH_CLIENT_SECRET    → from GitHub secret
OPENID_CONFIG_URL=https://login.microsoftonline.com/f7ce75d0-d142-4734-a71c-466edb42a1dd/v2.0/.well-known/openid-configuration
OIDC_SCOPE_OVERRIDE=openid,email,profile,offline_access
OIDC_PKCE_ENABLED=true
VALID_EMAIL_DOMAINS=naarni.com
WEB_DOMAIN=https://ai.naarni.com

################################################################################
## DATABASE
################################################################################
POSTGRES_USER=postgres
# POSTGRES_PASSWORD      → from GitHub secret
POSTGRES_HOST=relational_db
REDIS_HOST=cache
VESPA_HOST=index

################################################################################
## FILE STORE — AWS S3 (ap-south-1)
################################################################################
COMPOSE_PROFILES=
FILE_STORE_BACKEND=s3
AWS_REGION_NAME=ap-south-1
S3_FILE_STORE_BUCKET_NAME=naarni-onyx-docs-533267308676-ap-south-1-an
# S3_AWS_ACCESS_KEY_ID     → from GitHub secret
# S3_AWS_SECRET_ACCESS_KEY → from GitHub secret
S3_ENDPOINT_URL=https://s3.ap-south-1.amazonaws.com

################################################################################
## GEN AI MODEL
################################################################################
GEN_AI_MODEL_VERSION=gpt-4.1-mini
GEN_AI_MAX_INPUT_TOKENS=1000000

################################################################################
## OPENSEARCH — Disabled (Vespa only, saves ~3GB RAM)
################################################################################
OPENSEARCH_FOR_ONYX_ENABLED=false
ENABLE_OPENSEARCH_INDEXING_FOR_ONYX=false

################################################################################
## CORS — Widget domains
################################################################################
CORS_ALLOWED_ORIGIN=https://naarni.com,https://www.naarni.com,https://ai.naarni.com

################################################################################
## SERVICES
################################################################################
MODEL_SERVER_HOST=inference_model_server
INDEXING_MODEL_SERVER_HOST=indexing_model_server
INTERNAL_URL=http://api_server:8080

################################################################################
## LOGGING & FEATURES
################################################################################
LOG_LEVEL=info
LOG_ONYX_MODEL_INTERACTIONS=False
REQUIRE_EMAIL_VERIFICATION=False
ENABLE_PAID_ENTERPRISE_EDITION_FEATURES=False
VOICE_ENABLED=false
