<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ title }}</title>
<style>
@page {
    size: {{ page_size }};
    margin: 15mm;
    @bottom-right {
        content: counter(page) " / " counter(pages);
        font-family: {{ brand.font_family }};
        font-size: 8pt;
        color: #888;
    }
}

body {
    font-family: {{ brand.font_family }};
    font-size: 10pt;
    line-height: 1.5;
    color: #222;
}

.header-bar {
    display: flex;
    align-items: center;
    border-bottom: 1.5pt solid {{ brand.primary_color }};
    padding-bottom: 8pt;
    margin-bottom: 14pt;
}

.header-bar .logo {
    max-height: 28pt;
    max-width: 80pt;
    margin-right: 14pt;
}

.header-bar .title-block {
    flex: 1;
}

.header-bar .company-name {
    font-size: 9pt;
    color: {{ brand.secondary_color }};
    text-transform: uppercase;
    letter-spacing: 1pt;
}

.header-bar h1 {
    font-size: 16pt;
    color: {{ brand.primary_color }};
    margin: 2pt 0 0 0;
    border: none;
    padding: 0;
}

.header-bar .subtitle {
    font-size: 10pt;
    color: #555;
    margin-top: 2pt;
}

h3 {
    font-size: 12pt;
    color: {{ brand.primary_color }};
    margin-top: 14pt;
    margin-bottom: 6pt;
    page-break-after: avoid;
}

p {
    margin: 6pt 0;
}

ul {
    margin: 6pt 0;
    padding-left: 16pt;
}

ul li {
    margin: 2pt 0;
}

table {
    width: 100%;
    border-collapse: collapse;
    margin: 8pt 0;
    font-size: 9pt;
}

th {
    background-color: {{ brand.primary_color }};
    color: white;
    padding: 5pt 6pt;
    text-align: left;
}

td {
    padding: 4pt 6pt;
    border-bottom: 0.5pt solid #e0e0e0;
}

tr:nth-child(even) td {
    background-color: #fafafa;
}

.callout {
    border-left: 2pt solid {{ brand.primary_color }};
    background-color: {{ brand.primary_color }}12;
    padding: 6pt 10pt;
    margin: 8pt 0;
    font-size: 9.5pt;
}

code {
    font-family: "DejaVu Sans Mono", monospace;
    background-color: #f5f5f5;
    padding: 1pt 3pt;
    border-radius: 2pt;
    font-size: 9pt;
}

.footer {
    margin-top: 18pt;
    padding-top: 6pt;
    border-top: 0.5pt solid #ccc;
    font-size: 8pt;
    color: #888;
    text-align: center;
}
</style>
</head>
<body>

<div class="header-bar">
    {% if brand.logo_base64 %}
    <img class="logo" src="data:image/png;base64,{{ brand.logo_base64 }}" alt="Logo">
    {% endif %}
    <div class="title-block">
        {% if brand.company_name %}<div class="company-name">{{ brand.company_name }}</div>{% endif %}
        <h1>{{ title }}</h1>
        {% if subtitle %}<div class="subtitle">{{ subtitle }}</div>{% endif %}
    </div>
</div>

{% for section in sections %}
<div>
    <h3>{{ section.heading }}</h3>

    {% if section.body %}
    <p>{{ section.body | inline_format | safe }}</p>
    {% endif %}

    {% if section.bullet_points %}
    <ul>
        {% for point in section.bullet_points %}
        <li>{{ point | inline_format | safe }}</li>
        {% endfor %}
    </ul>
    {% endif %}

    {% if section.table %}
    <table>
        <thead>
            <tr>
                {% for header in section.table.headers %}<th>{{ header }}</th>{% endfor %}
            </tr>
        </thead>
        <tbody>
            {% for row in section.table.rows %}
            <tr>
                {% for cell in row %}<td>{{ cell }}</td>{% endfor %}
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}

    {% if section.callout %}
    <div class="callout">{{ section.callout | inline_format | safe }}</div>
    {% endif %}
</div>
{% endfor %}

<div class="footer">
    {{ generated_at }}
</div>

</body>
</html>
