<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ title }}</title>
<style>
@page {
    size: {{ page_size }};
    margin: 20mm;
    @bottom-center {
        content: "Page " counter(page) " of " counter(pages);
        font-family: {{ brand.font_family }};
        font-size: 9pt;
        color: #888;
    }
    @top-right {
        content: string(section-title);
        font-family: {{ brand.font_family }};
        font-size: 9pt;
        color: #888;
    }
}

body {
    font-family: {{ brand.font_family }};
    font-size: 11pt;
    line-height: 1.6;
    color: #222;
}

h1 {
    font-size: 24pt;
    color: {{ brand.primary_color }};
    border-bottom: 2pt solid {{ brand.primary_color }};
    padding-bottom: 8pt;
    margin-top: 0;
}

h2 {
    font-size: 18pt;
    color: {{ brand.primary_color }};
    margin-top: 24pt;
    margin-bottom: 12pt;
    page-break-after: avoid;
    string-set: section-title content();
}

h3 {
    font-size: 14pt;
    color: {{ brand.secondary_color }};
    margin-top: 18pt;
}

p {
    margin: 8pt 0;
}

ul {
    margin: 8pt 0;
    padding-left: 20pt;
}

ul li {
    margin: 4pt 0;
}

table {
    width: 100%;
    border-collapse: collapse;
    margin: 12pt 0;
    font-size: 10pt;
}

th {
    background-color: {{ brand.primary_color }};
    color: white;
    padding: 8pt;
    text-align: left;
    font-weight: 600;
}

td {
    padding: 6pt 8pt;
    border-bottom: 0.5pt solid #e0e0e0;
}

tr:nth-child(even) td {
    background-color: #fafafa;
}

.callout {
    border-left: 3pt solid {{ brand.primary_color }};
    background-color: {{ brand.primary_color }}12;
    padding: 10pt 14pt;
    margin: 12pt 0;
    border-top-right-radius: 4pt;
    border-bottom-right-radius: 4pt;
}

code {
    font-family: "DejaVu Sans Mono", monospace;
    background-color: #f5f5f5;
    padding: 1pt 4pt;
    border-radius: 2pt;
    font-size: 9.5pt;
}

pre {
    font-family: "DejaVu Sans Mono", monospace;
    background-color: #f5f5f5;
    padding: 10pt;
    border-radius: 4pt;
    font-size: 9pt;
    line-height: 1.4;
    white-space: pre-wrap;
}

.cover-page {
    height: 90vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    page-break-after: always;
}

.cover-page .logo {
    max-width: 180pt;
    max-height: 90pt;
    margin-bottom: 32pt;
}

.cover-page .company-name {
    font-size: 14pt;
    color: {{ brand.secondary_color }};
    letter-spacing: 2pt;
    text-transform: uppercase;
    margin-bottom: 12pt;
}

.cover-page h1 {
    font-size: 36pt;
    border: none;
    margin: 0 0 16pt 0;
    padding: 0;
}

.cover-page .subtitle {
    font-size: 16pt;
    color: #555;
    margin-bottom: 48pt;
}

.cover-page .metadata {
    font-size: 11pt;
    color: #555;
    margin-top: 24pt;
}

.cover-page .metadata div {
    margin: 3pt 0;
}

.toc {
    page-break-after: always;
}

.toc h2 {
    border-bottom: 1pt solid {{ brand.primary_color }};
    padding-bottom: 4pt;
    string-set: section-title "Contents";
}

.toc ol {
    list-style: none;
    padding: 0;
    margin: 16pt 0 0 0;
}

.toc ol li {
    margin: 6pt 0;
    font-size: 11pt;
}

.toc ol li a {
    text-decoration: none;
    color: #222;
}

.toc ol li a::after {
    content: leader(".") " " target-counter(attr(href), page);
    color: #888;
}

.section {
    page-break-before: always;
}

.footer {
    margin-top: 48pt;
    padding-top: 12pt;
    border-top: 0.5pt solid #ccc;
    font-size: 9pt;
    color: #888;
    text-align: center;
}

{# ─── WATERMARK ──────────────────────────────────────────────
   position: fixed + WeasyPrint → the container is painted on every
   generated page. We over-size the container (300% viewport) and rotate
   the whole grid so the repeated text reads as diagonal stripes. Low
   opacity keeps it professional and non-obstructive over body text.
#}
.watermark {
    position: fixed;
    top: -100%;
    left: -100%;
    right: -100%;
    bottom: -100%;
    width: 300%;
    height: 300%;
    transform: rotate(-30deg);
    transform-origin: center center;
    pointer-events: none;
    z-index: -1;
    overflow: hidden;
    display: flex;
    flex-wrap: wrap;
    align-content: space-around;
    justify-content: space-around;
}

.watermark-tile {
    display: inline-block;
    font-family: {{ brand.font_family }};
    font-size: 28pt;
    font-weight: 600;
    letter-spacing: 2pt;
    color: {{ brand.watermark_color }};
    opacity: 0.06;
    white-space: nowrap;
    padding: 30pt 60pt;
}
</style>
</head>
<body>

{# ─── WATERMARK (every page, diagonal, very light) ────────── #}
{% if brand.watermark_text %}
<div class="watermark" aria-hidden="true">
    {# 48 tiles gives good coverage across A4/Letter at any orientation. #}
    {% for _ in range(48) %}
    <span class="watermark-tile">{{ brand.watermark_text }}</span>
    {% endfor %}
</div>
{% endif %}

{# ─── COVER PAGE ──────────────────────────────────────────── #}
<div class="cover-page">
    {% if brand.logo_base64 %}
    <img class="logo" src="data:image/png;base64,{{ brand.logo_base64 }}" alt="Logo">
    {% endif %}
    {% if brand.company_name %}
    <div class="company-name">{{ brand.company_name }}</div>
    {% endif %}
    <h1>{{ title }}</h1>
    {% if subtitle %}<div class="subtitle">{{ subtitle }}</div>{% endif %}
    {% if metadata %}
    <div class="metadata">
        {% if metadata.author %}<div><strong>Author:</strong> {{ metadata.author }}</div>{% endif %}
        {% if metadata.department %}<div><strong>Department:</strong> {{ metadata.department }}</div>{% endif %}
        {% if metadata.date %}<div><strong>Date:</strong> {{ metadata.date }}</div>{% endif %}
        {% if metadata.confidentiality %}<div><strong>Classification:</strong> {{ metadata.confidentiality }}</div>{% endif %}
    </div>
    {% endif %}
</div>

{# ─── TABLE OF CONTENTS ───────────────────────────────────── #}
{% if include_toc and sections|length > 1 %}
<nav class="toc">
    <h2>Contents</h2>
    <ol>
        {% for section in sections %}
        <li><a href="#section-{{ loop.index }}">{{ section.heading }}</a></li>
        {% endfor %}
    </ol>
</nav>
{% endif %}

{# ─── SECTIONS ────────────────────────────────────────────── #}
{% for section in sections %}
<section class="section" id="section-{{ loop.index }}">
    <h2>{{ section.heading }}</h2>

    {% if section.body %}
    <p>{{ section.body | inline_format | safe }}</p>
    {% endif %}

    {% if section.bullet_points %}
    <ul>
        {% for point in section.bullet_points %}
        <li>{{ point | inline_format | safe }}</li>
        {% endfor %}
    </ul>
    {% endif %}

    {% if section.table %}
    <table>
        <thead>
            <tr>
                {% for header in section.table.headers %}<th>{{ header }}</th>{% endfor %}
            </tr>
        </thead>
        <tbody>
            {% for row in section.table.rows %}
            <tr>
                {% for cell in row %}<td>{{ cell }}</td>{% endfor %}
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}

    {% if section.callout %}
    <div class="callout">{{ section.callout | inline_format | safe }}</div>
    {% endif %}
</section>
{% endfor %}

<div class="footer">
    Generated on {{ generated_at }}
</div>

</body>
</html>
